        deployPrivate: createDeployment(provider: $provider, visibility: private) {
          isAuthorized
          code
          message
        }
        deployPassword: createDeployment(provider: $provider, visibility: password) {
          isAuthorized
          code
          message
        }
        redeployPublic: redeployDeployment(provider: $provider, visibility: public) {
          isAuthorized
          code
          message
        }
        redeployPrivate: redeployDeployment(provider: $provider, visibility: private) {
          isAuthorized
          code
          message
        }
        redeployPassword: redeployDeployment(provider: $provider, visibility: password) {
          isAuthorized
          code
          message
        }
      }
    }
  }
}
