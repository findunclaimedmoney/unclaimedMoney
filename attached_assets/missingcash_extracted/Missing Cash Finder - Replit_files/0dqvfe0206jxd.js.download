    mutation NotificationsSectionUpdateFailureNotifications($input: UpdateMachineJobFailureNotificationInput!) {
  updateMachineJobFailureNotification(input: $input) {
    ... on UnauthorizedError {
      message
    }
    ... on NotFoundError {
      message
    }
    ... on UserError {
      message
    }
