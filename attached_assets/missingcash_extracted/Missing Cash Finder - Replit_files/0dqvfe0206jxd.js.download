    query HostingDeploymentConfigRedeploy($id: String!) {
  hostingDeployment(id: $id) {
    ... on HostingDeployment {
      id
      replitAppSubdomain
      ignoredSecrets
      activityLogs(count: 20) {
        items {
          id
          ...HostingActivityLogLine2
        }
        pageInfo {
          hasNextPage
          nextCursor
        }
      }
      currentBuild {
        id
        envVars {
          name
          value
        }
        suspendedReason
        machineConfiguration {
          id
          label
          vcpu
          memory
          slug
        }
        maxMachineInstances
        provider
      }
      ...DeploymentsDeployOptionsDeployment
      repl {
        id
        authorizations {
          editDeploymentSecrets {
            isAuthorized
            message
          }
          editSecrets {
            isAuthorized
            message
          }
        }
      }
    }
  }
