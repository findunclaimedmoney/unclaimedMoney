    query UsersTabReplitAuthUsers($id: String!, $count: Int, $after: String, $orderBy: ReplitAuthUserOrderByInput, $filter: ReplitAuthUserFilterInput, $clerkEnvironment: ClerkEnvironment) {
  getRepl(id: $id) {
    ... on Repl {
      id
      authUsers(
        count: $count
        after: $after
        orderBy: $orderBy
        filter: $filter
        clerkEnvironment: $clerkEnvironment
      ) {
        items {
          id
          banned
          timeCreated
          lastLoggedIn
          displayName
          image
          email
          externalId
          userId
          userIdString
        }
        pageInfo {
          hasNextPage
          nextCursor
        }
      }
    }
  }
}
    `,e9=eh.gql`
    mutation UsersTabUpdateReplitAuthUserBanStatus($input: UpdateReplitAuthUserBanStatusInput!) {
  updateReplitAuthUserBanStatus(input: $input) {
    ... on UpdateReplitAuthUserBanStatusOutput {
      success
      message
      user {
        id
        banned
      }
    }
    ... on NotFoundError {
      message
    }
    ... on UnauthorizedError {
      message
    }
  }
}
