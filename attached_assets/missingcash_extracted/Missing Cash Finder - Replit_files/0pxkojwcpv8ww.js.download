    query TeamMultiplayerManagerMultiplayers($replId: String!) {
  currentUser {
    id
    username
    fullName
    image
  }
  getRepl(id: $replId) {
    ... on Repl {
      id
      isOwner
      org {
        id
        customer {
          ... on Customer {
            ...InvitePromotionsCustomer
          }
        }
      }
      collaborators {
        type
        permission
        user {
          ...MultiplayerUser
        }
      }
      authorizations {
        editPermissions {
          isAuthorized
        }
        inviteGuests {
          isAuthorized
        }
      }
      multiplayerInvites {
        email
        type
      }
      owner {
        ... on User {
          id
        }
        ... on Team {
          id
          username
          displayName
          capabilities {
            isBusinessPlan
            hasValidSubscription
            availableSeats
          }
          members {
            id
            permissions
            user {
              id
              ...MultiplayerUser
            }
          }
        }
      }
    }
  }
}
