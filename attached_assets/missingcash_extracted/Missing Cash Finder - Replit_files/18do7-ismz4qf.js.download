    query CollaborationEducationCardRepl($replId: String!, $threshold: Int!) {
  getRepl(id: $replId) {
    ... on Repl {
      id
      checkpointCountExceeds(threshold: $threshold)
      owner {
        __typename
        ... on User {
          id
        }
        ... on Team {
          id
        }
      }
      org {
        id
      }
      multiplayers {
        id
      }
      multiplayerInvites {
        email
      }
      authorizations {
        editPermissions {
          isAuthorized
        }
      }
    }
  }
}
