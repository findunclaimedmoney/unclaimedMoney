 URL.","costsIncludedInSubscription":"Costs are included in {planName} subscriptions","watchVideo":"Watch video","learnMore":"Learn more","publishButton":"Publish","cancelButton":"Cancel","buildCancelled":"Build cancelled","publishing":"Publishing","hideLogs":"Hide logs","viewLogs":"View logs","logsFormatJson":"Format JSON","logsFormatJsonTooltip":"Pretty-print log lines that contain JSON","stageProvision":"Provision","stageSecurityScan":"Security Scan","stageBuild":"Build","stageBundle":"Bundle","stagePromote":"Promote","buildFailed":"Build failed","promotionFailed":"Promotion failed","publishingFailed":"Publishing failed","appFailedToPromote":"Your app failed to promote","appFailedToBuild":"Your app failed to build","debugWithAgent":"Debug with {agentName}","viewAll":"View all","tabOverview":"Overview","tabSchedule":"Schedule","tabLogs":"Logs","tabAnalytics":"Analytics","tabResources":"Resources","tabDomains":"Domains","tabManage":"Manage","preparingButton":"Preparing...","fetchingOptionsButton":"Fetching options...","gitRemoteRequired":"Git remote required. Add a remote repository to publish your app","branchNotPushed":"Your branch is not pushed. Push your branch to publish your app","uncommittedChanges":"You have uncommitted changes. Commit and push your changes to publish","unpushedCommits":"You have unpushed commits. Push your commits to publish your app","upgradeYourPlanToPublish":"Upgrade your plan to publish","addPaymentMethod":"Add a payment method","accountRestricted":"Your account currently has restrictions on publishing. We\'re here to help! Please reach out to support@replit.com for assistance.","monthlyBudgetReached":"You\'ve reached your monthly usage budget. Increase your budget to continue publishing.","maxStaticAppsReached":"You have reached the maximum number of Static published apps available on your plan.","userUsageThresholdExceeded":"You have exceeded your usage threshold","groupUsageThresholdExceeded":"Your group has exceeded its usage thres